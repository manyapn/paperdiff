{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperdiff.local/contracts/challenge-request.schema.json",
  "title": "PaperDiff Challenge request",
  "type": "object",
  "additionalProperties": false,
  "required": ["input"],
  "properties": {
    "input": {
      "type": "string",
      "minLength": 1,
      "maxLength": 10000,
      "description": "A paper URL, DOI, abstract, or scientific claim to resolve through live Linkup retrieval."
    }
  }
}
