{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperdiff.local/contracts/challenge-response.schema.json",
  "title": "PaperDiff Challenge response",
  "type": "object",
  "additionalProperties": false,
  "required": ["trace_id", "pipeline_version", "source", "candidates", "trace"],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "pipeline_version": { "const": "paperdiff-challenge-v1" },
    "source": { "$ref": "#/$defs/source" },
    "candidates": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "trace": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/trace" }
    }
  },
  "$defs": {
    "url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "passage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_url", "span_id", "pre", "span", "post"],
      "properties": {
        "source_url": { "$ref": "#/$defs/url" },
        "span_id": { "type": "string", "minLength": 1 },
        "pre": { "type": "string" },
        "span": { "type": "string", "minLength": 1 },
        "post": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "checks", "failure_reasons"],
      "properties": {
        "passed": { "type": "boolean" },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source_origin", "fetched", "identity_match", "passage_match", "span_specific"],
          "properties": {
            "source_origin": { "type": "boolean" },
            "fetched": { "type": "boolean" },
            "identity_match": { "type": "boolean" },
            "passage_match": { "type": "boolean" },
            "span_specific": { "type": "boolean" }
          }
        },
        "failure_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "authors", "venue", "year", "source_url", "passages", "identity_passage", "provenance"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "authors": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "venue": { "type": "string" },
        "year": { "type": ["integer", "null"], "minimum": 1000, "maximum": 3000 },
        "source_url": { "$ref": "#/$defs/url" },
        "passages": { "type": "integer", "minimum": 1 },
        "identity_passage": { "$ref": "#/$defs/passage" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "fit",
        "points",
        "source_value",
        "candidate_value",
        "rationale",
        "source_passage",
        "candidate_passage",
        "source_provenance",
        "candidate_provenance",
        "icon",
        "color"
      ],
      "properties": {
        "key": {
          "enum": [
            "population",
            "intervention_or_exposure",
            "comparator",
            "outcome",
            "time_horizon",
            "design",
            "analysis"
          ]
        },
        "label": { "type": "string", "minLength": 1 },
        "fit": { "enum": ["match", "partial", "mismatch", "review"] },
        "points": { "enum": [0, 0.5, 1] },
        "source_value": { "type": "string" },
        "candidate_value": { "type": "string" },
        "rationale": { "type": "string", "minLength": 1 },
        "source_passage": { "oneOf": [{ "$ref": "#/$defs/passage" }, { "type": "null" }] },
        "candidate_passage": { "oneOf": [{ "$ref": "#/$defs/passage" }, { "type": "null" }] },
        "source_provenance": { "$ref": "#/$defs/provenance" },
        "candidate_provenance": { "$ref": "#/$defs/provenance" },
        "icon": { "enum": ["=", "≈", "≠", "?"] },
        "color": { "enum": ["#1746B7", "#A65F00", "#A93F35", "#566173"] }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "authors",
        "venue",
        "year",
        "url",
        "relationship_type",
        "comparison_fit",
        "fit_score",
        "explanation",
        "citations",
        "relationship_source_passage",
        "relationship_candidate_passage",
        "source_provenance",
        "candidate_provenance",
        "dimensions"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "authors": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "venue": { "type": "string" },
        "year": { "type": ["integer", "null"], "minimum": 1000, "maximum": 3000 },
        "url": { "$ref": "#/$defs/url" },
        "relationship_type": {
          "enum": ["closest contradictory result", "direct replication", "best later reassessment"]
        },
        "comparison_fit": { "enum": ["high", "medium", "review"] },
        "fit_score": { "type": "number", "minimum": 0, "maximum": 7, "multipleOf": 0.5 },
        "explanation": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/url" }
        },
        "relationship_source_passage": { "$ref": "#/$defs/passage" },
        "relationship_candidate_passage": { "$ref": "#/$defs/passage" },
        "source_provenance": { "$ref": "#/$defs/provenance" },
        "candidate_provenance": { "$ref": "#/$defs/provenance" },
        "dimensions": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/$defs/dimension" }
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "status", "detail", "provider", "latency_ms"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "status": { "enum": ["complete", "blocked", "review"] },
        "detail": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "latency_ms": { "type": "number", "minimum": 0 },
        "source_url": { "$ref": "#/$defs/url" }
      }
    }
  }
}
