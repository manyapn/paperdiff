{
  "name": "paperdiff-compare",
  "description": "Compare-mode pipeline, v2. Provenance/classifier/assembly logic lives in pipeline/service/app.py (hosted separately) since no RocketRide node type runs a fixed script deterministically -- confirmed by checking PREPROCESSOR>Code (text/code chunker), TOOL>Python (agent writes code fresh per call), GUARD (content-safety filter only), and DATA (document parsers only). Each stage is now called via tool_http_request under an orchestrating agent's control, with a system prompt that forbids editorializing the tool's output.",
  "version": 1,
  "components": [
    {
      "id": "in",
      "provider": "webhook",
      "name": "Webhook",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 0
        },
        "nodeType": "default",
        "formDataValid": false
      }
    },
    {
      "id": "extract_left",
      "provider": "agent_rocketride",
      "name": "RocketRide Wave",
      "config": {
        "systemPrompt": "Input is the 'left' side of a Compare request: {url, claim, use_detected_conclusion}. If url is set, use linkup_fetch_left to retrieve the paper. Extract and return JSON: {title, authors: [string], venue, year, source_url, passages: <int>, dimensions: {research_question, population, exposure_or_intervention, outcome, method, baseline, time_horizon, exclusions, stated_conclusion}, dimensions_evidence: {<field>: {quote, pre, post}}}. Never invent a field you cannot support with an exact quote -- return null and omit its evidence instead of guessing. If url is null, source_url is null, passages is 0, and the user-provided claim is the stated_conclusion with no further extraction."
      },
      "ui": {
        "position": {
          "x": -300,
          "y": -300
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "questions",
          "from": "in"
        }
      ]
    },
    {
      "id": "extract_left_llm",
      "provider": "llm_anthropic",
      "name": "Anthropic",
      "config": {
        "model": "claude-sonnet-4-6"
      },
      "ui": {
        "position": {
          "x": -500,
          "y": -100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "llm",
          "from": "extract_left"
        }
      ]
    },
    {
      "id": "extract_left_memory",
      "provider": "memory_internal",
      "name": "Memory (Internal)",
      "config": {},
      "ui": {
        "position": {
          "x": -300,
          "y": -100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "memory",
          "from": "extract_left"
        }
      ]
    },
    {
      "id": "linkup_fetch_left",
      "provider": "tool_http_request",
      "name": "HTTP Request",
      "config": {
        "method": "POST",
        "url": "https://api.linkup.so/v1/search",
        "headers": {
          "Authorization": "Bearer ${LINKUP_API_KEY}",
          "Content-Type": "application/json"
        }
      },
      "ui": {
        "position": {
          "x": -100,
          "y": -100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "tool",
          "from": "extract_left"
        }
      ]
    },
    {
      "id": "extract_right",
      "provider": "agent_rocketride",
      "name": "RocketRide Wave",
      "config": {
        "systemPrompt": "Same extraction schema and rules as the left extractor, applied to the 'right' side of the Compare request. Use linkup_fetch_right if a url is present."
      },
      "ui": {
        "position": {
          "x": 300,
          "y": -300
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "questions",
          "from": "in"
        }
      ]
    },
    {
      "id": "extract_right_llm",
      "provider": "llm_anthropic",
      "name": "Anthropic",
      "config": {
        "model": "claude-sonnet-4-6"
      },
      "ui": {
        "position": {
          "x": 100,
          "y": -100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "llm",
          "from": "extract_right"
        }
      ]
    },
    {
      "id": "extract_right_memory",
      "provider": "memory_internal",
      "name": "Memory (Internal)",
      "config": {},
      "ui": {
        "position": {
          "x": 300,
          "y": -100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "memory",
          "from": "extract_right"
        }
      ]
    },
    {
      "id": "linkup_fetch_right",
      "provider": "tool_http_request",
      "name": "HTTP Request",
      "config": {
        "method": "POST",
        "url": "https://api.linkup.so/v1/search",
        "headers": {
          "Authorization": "Bearer ${LINKUP_API_KEY}",
          "Content-Type": "application/json"
        }
      },
      "ui": {
        "position": {
          "x": 500,
          "y": -100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "tool",
          "from": "extract_right"
        }
      ]
    },
    {
      "id": "aligner",
      "provider": "agent_rocketride",
      "name": "RocketRide Wave",
      "config": {
        "systemPrompt": "Given both extracted papers, produce the `dimensions` array for the Compare response: for each of the 9 dimension keys, output {key, label, classification: 'equivalent'|'different'|'incompatible'|'review', left_value, right_value, rationale, drives_verdict: bool, left_evidence, right_evidence (pass through unchanged)}. Use 'review' when either side's value is null -- never classify equivalent/different when one side is missing data. drives_verdict=true only for the 2-3 dimensions that most explain the apparent disagreement."
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "answers",
          "from": "extract_left"
        },
        {
          "lane": "answers",
          "from": "extract_right"
        }
      ]
    },
    {
      "id": "aligner_llm",
      "provider": "llm_anthropic",
      "name": "Anthropic",
      "config": {
        "model": "claude-sonnet-4-6"
      },
      "ui": {
        "position": {
          "x": -150,
          "y": 250
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "llm",
          "from": "aligner"
        }
      ]
    },
    {
      "id": "aligner_memory",
      "provider": "memory_internal",
      "name": "Memory (Internal)",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 250
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "memory",
          "from": "aligner"
        }
      ]
    },
    {
      "id": "verification_agent",
      "provider": "agent_rocketride",
      "name": "RocketRide Wave",
      "config": {
        "systemPrompt": "You orchestrate two fixed, deterministic checks. Do not perform validation or classification yourself -- only call the tools and relay their output. Step 1: call provenance_check with the aligner's full output as the request body. Step 2: call classify_evidence with EXACTLY the JSON that provenance_check returned as the request body. Return classify_evidence's response verbatim as your answer, unmodified -- no summarizing, no commentary, no reformatting."
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 400
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "answers",
          "from": "aligner"
        }
      ]
    },
    {
      "id": "verification_llm",
      "provider": "llm_anthropic",
      "name": "Anthropic",
      "config": {
        "model": "claude-sonnet-4-6"
      },
      "ui": {
        "position": {
          "x": -200,
          "y": 550
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "llm",
          "from": "verification_agent"
        }
      ]
    },
    {
      "id": "verification_memory",
      "provider": "memory_internal",
      "name": "Memory (Internal)",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 550
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "memory",
          "from": "verification_agent"
        }
      ]
    },
    {
      "id": "provenance_check",
      "provider": "tool_http_request",
      "name": "HTTP Request",
      "config": {
        "method": "POST",
        "url": "${PAPERDIFF_SERVICE_URL}/provenance",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "ui": {
        "position": {
          "x": 200,
          "y": 500
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "tool",
          "from": "verification_agent"
        }
      ]
    },
    {
      "id": "classify_evidence",
      "provider": "tool_http_request",
      "name": "HTTP Request",
      "config": {
        "method": "POST",
        "url": "${PAPERDIFF_SERVICE_URL}/classify",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "ui": {
        "position": {
          "x": 400,
          "y": 550
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "tool",
          "from": "verification_agent"
        }
      ]
    },
    {
      "id": "verdict_agent",
      "provider": "agent_rocketride",
      "name": "RocketRide Wave",
      "config": {
        "systemPrompt": "Given the aligned, provenance-checked, classified dimensions, write the Compare response's `verdict` (headline + explanation), `synthesis` (one jointly-supportable sentence with citations), and `evidence_summary` (one sentence). Base the headline on drives_verdict dimensions only. If a dimension's evidence_status is 'Needs review' or 'Blocked', hedge explicitly rather than stating its classification as settled fact. Append these three fields to the input data and pass everything through unchanged otherwise."
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 700
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "answers",
          "from": "verification_agent"
        }
      ]
    },
    {
      "id": "verdict_llm",
      "provider": "llm_anthropic",
      "name": "Anthropic",
      "config": {
        "model": "claude-sonnet-4-6"
      },
      "ui": {
        "position": {
          "x": -200,
          "y": 850
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "llm",
          "from": "verdict_agent"
        }
      ]
    },
    {
      "id": "verdict_memory",
      "provider": "memory_internal",
      "name": "Memory (Internal)",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 850
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "memory",
          "from": "verdict_agent"
        }
      ]
    },
    {
      "id": "finalizer_agent",
      "provider": "agent_rocketride",
      "name": "RocketRide Wave",
      "config": {
        "systemPrompt": "Call assemble_response with the full accumulated data (papers, dimensions, verdict, synthesis, evidence_summary) as the request body. Return its response verbatim as your final answer -- do not modify, summarize, or add anything. This is pure formatting, not a judgment call."
      },
      "ui": {
        "position": {
          "x": 0,
          "y": 1000
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "input": [
        {
          "lane": "answers",
          "from": "verdict_agent"
        }
      ]
    },
    {
      "id": "finalizer_llm",
      "provider": "llm_anthropic",
      "name": "Anthropic",
      "config": {
        "model": "claude-sonnet-4-6"
      },
      "ui": {
        "position": {
          "x": -200,
          "y": 1150
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "llm",
          "from": "finalizer_agent"
        }
      ]
    },
    {
      "id": "finalizer_memory",
      "provider": "memory_internal",
      "name": "Memory (Internal)",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 1150
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "memory",
          "from": "finalizer_agent"
        }
      ]
    },
    {
      "id": "assemble_response",
      "provider": "tool_http_request",
      "name": "HTTP Request",
      "config": {
        "method": "POST",
        "url": "${PAPERDIFF_SERVICE_URL}/assemble",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "ui": {
        "position": {
          "x": 200,
          "y": 1100
        },
        "nodeType": "default",
        "formDataValid": false
      },
      "control": [
        {
          "classType": "tool",
          "from": "finalizer_agent"
        }
      ]
    },
    {
      "id": "out",
      "provider": "response",
      "config": {},
      "ui": {
        "position": {
          "x": 0,
          "y": 1300
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "answers",
          "from": "finalizer_agent"
        }
      ]
    }
  ],
  "project_id": "6c582a65-08f5-4acd-80df-5b6bb1d4649e"
}