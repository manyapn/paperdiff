# Copy to .env. Never commit real keys.
PAPERDIFF_ENV=development
PAPERDIFF_DEMO_MODE=true
PAPERDIFF_CORS_ORIGINS=http://localhost:5173
PAPERDIFF_API_URL=http://localhost:8000

# Required for live paper retrieval. Demo mode works without it.
LINKUP_API_KEY=

# Configure only after installing the extension and confirming the current SDK/API.
ROCKETRIDE_APIKEY=

# Optional verifier provider. The deterministic provenance gate still runs first.
OPENAI_API_KEY=
PAPERDIFF_VERIFIER_MODEL=

